APP_NAME="Inventario Multisede"

APP_ENV=local

APP_KEY=

APP_DEBUG=true

APP_URL=http://127.0.0.1:8000



LOG_CHANNEL=stack

LOG_LEVEL=debug



# Supabase Postgres (pooler). Usuario: postgres.TU_PROJECT_REF (no solo "postgres").

DB_CONNECTION=pgsql

DB_HOST=localhost

DB_PORT=5432

DB_DATABASE=prueba

DB_USERNAME=postgres

DB_PASSWORD=123456

DB_SCHEMA=inventario_v2,public



INVENTARIO_PG_CONFIG=../inventario_pg_config copy.json



# Rendimiento: evitar OneDrive en sesiones/caché (descomenta y usa carpeta local)

# SESSION_PATH=C:/temp/laravel-inventario/sessions

# CACHE_PATH=C:/temp/laravel-inventario/cache

CACHE_STORE=file

SESSION_DRIVER=file

SESSION_LIFETIME=120



PER_PAGE=75

SYNC_INTERVAL_MS=60000

LAST_STOCK_UPDATE_CACHE_SECONDS=30

